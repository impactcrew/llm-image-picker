# Copy this file to .env and fill in your key(s):  cp .env.example .env
#
# Your real .env is gitignored: it stays on your machine and is never
# committed or pushed. Never paste these keys into an AI chat. Type them
# into the .env file in your editor instead.

# Required. Get a free key at: https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional. Adds illustrations and vectors. https://pixabay.com/api/docs/
PIXABAY_API_KEY=
