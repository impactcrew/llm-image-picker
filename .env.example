# This shows the key format for /img. Put these lines in EITHER:
#   - the global config file (recommended):  ~/.config/llm-image-picker/keys.env
#   - or a project-local .env in the folder you run /img from
#
# Your real key file stays on your machine. Never commit it, and never
# paste these keys into an AI chat. Type them into the file in your editor.

# Required. Get a free key at: https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional. Adds illustrations and vectors. https://pixabay.com/api/docs/
PIXABAY_API_KEY=
